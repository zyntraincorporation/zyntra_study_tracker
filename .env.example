# ─────────────────────────────────────────
# ZYNTRA STUDY TRACKER OS — Environment Variables
# Copy this to /server/.env and /client/.env and fill in real values
# ─────────────────────────────────────────

# ── SERVER (/server/.env) ──────────────────────────────────────────────────────

# PostgreSQL — Neon serverless connection string
# Get this from: https://console.neon.tech → your project → Connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST/zyntra?sslmode=require"

# OpenRouter API key — used for GPT-4o mini analysis
# Get this from: https://openrouter.ai/keys
OPENROUTER_API_KEY="sk-or-v1-..."

# Single-user PIN for app access (min 4 digits)
APP_PIN=1234

# JWT secret — used to sign the session token after PIN login
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="replace_with_64_char_random_hex_string"

# Port the Express server listens on (Render sets this automatically)
PORT=3001

# CORS origin — set to your Netlify URL in production
CLIENT_ORIGIN="http://localhost:5173"

# Node environment
NODE_ENV="development"


# ── CLIENT (/client/.env) ──────────────────────────────────────────────────────

# Your Render backend URL (no trailing slash)
# In development: http://localhost:3001
# In production:  https://zyntra-api.onrender.com  (use your actual Render URL)
VITE_API_BASE_URL="http://localhost:3001"

# Neon requires a direct (non-pooled) connection URL for migrations
# Get this from: Neon console → Connection string → toggle "Pooled connection" OFF
DIRECT_URL="postgresql://USER:PASSWORD@HOST/zyntra?sslmode=require"
